{
  "_comment": "Copy this file to deploy-config.json and fill in your own GCP values. deploy-config.json is gitignored.",
  "defaults": {
    "region": "YOUR_GCP_REGION",
    "resources": {
      "memory": "512Mi",
      "cpu": "1",
      "concurrency": 80,
      "timeout": 300,
      "min_instances": 0,
      "max_instances": 5
    }
  },
  "environments": {
    "prod": {
      "project_id": "YOUR_GCP_PROJECT_ID",
      "service_name": "somanylemons-mcp",
      "api_url": "https://api.example.com",
      "artifact_registry": "YOUR_REGION-docker.pkg.dev/YOUR_PROJECT/YOUR_REPO",
      "resources": {
        "min_instances": 1,
        "max_instances": 10
      }
    },
    "qas": {
      "project_id": "YOUR_QAS_PROJECT_ID",
      "service_name": "somanylemons-mcp-qas",
      "api_url": "https://api.qas.example.com",
      "artifact_registry": "YOUR_REGION-docker.pkg.dev/YOUR_QAS_PROJECT/YOUR_REPO",
      "resources": {
        "min_instances": 0,
        "max_instances": 3
      }
    }
  }
}
